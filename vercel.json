{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "frontend": {
      "root": "adr_prediction/frontend"
    },
    "backend": {
      "root": "adr_prediction/backend",
      "entrypoint": "Dockerfile"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": { "service": "backend", "path": "/$1" } },
    { "source": "/(.*)", "destination": { "service": "frontend", "path": "/$1" } }
  ]
}
